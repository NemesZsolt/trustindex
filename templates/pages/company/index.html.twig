{% extends '/layouts/base.html.twig' %}

{% block title %}Trustindex | Companies{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="mb-4">Companies</h1>

        <div
            data-controller="datatable"
            data-datatable-order-column-value="2"
            data-datatable-order-dir-value="desc"
        >
            <table class="table table-striped" data-datatable-target="table">
                <thead>
                <tr>
                    <th>Company</th>
                    <th>Reviews</th>
                    <th>Average Rating</th>
                </tr>
                </thead>
                <tbody>
                {% for company in company_stats %}
                    <tr>
                        <td>
                            {{ company.companyName }}
                        </td>
                        <td>{{ company.reviewCount }}</td>
                        <td data-order="{{ company.averageRating }}">
                            {% set avg = company.averageRating|round(1) %}
                            {% for i in 1..5 %}
                                <i class="bi bi-star{% if i <= avg %}-fill{% endif %} text-warning"></i>
                            {% endfor %}
                            <span class="ms-2 text-muted">{{ avg }}</span>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
